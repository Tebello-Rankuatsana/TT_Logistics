<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ranks.one.Testing">
   <children>
      <TextArea fx:id="txtDisplay" layoutX="101.0" layoutY="169.0" prefHeight="200.0" prefWidth="418.0" promptText="database contents to be displayed here" style="-fx-font-alignment: center;">
         <font>
            <Font size="19.0" />
         </font>
      </TextArea>
      <Button fx:id="btnPress" layoutX="227.0" layoutY="89.0" mnemonicParsing="false" onAction="#handlePress" prefHeight="46.0" prefWidth="148.0" text="Press Me!!!" textFill="RED">
         <font>
            <Font name="Chiller" size="23.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
